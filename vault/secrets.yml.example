---
# Copy to secrets.yml and encrypt with: ansible-vault encrypt vault/secrets.yml
# These values will be deployed to the Ziggy VM.

# Anthropic
anthropic_api_key: "sk-ant-..."

# Brave Search
brave_search_api_key: "BSA..."

# Telegram
telegram_bot_token: "..."

# GitHub
ziggy_github_pat: "ghp_..."
# ziggy_ssh_private_key: |
#   -----BEGIN OPENSSH PRIVATE KEY-----
#   ...
#   -----END OPENSSH PRIVATE KEY-----
# ziggy_ssh_public_key: "ssh-ed25519 AAAA..."

# Twilio
twilio_sid: "AC..."
twilio_auth_token: "..."
twilio_number: "REDACTED_PHONE_8"

# Google OAuth (copy from ~/.config/ziggy/ on the VM)
# ziggy_google_credentials: { ... }
# ziggy_google_tokens: { ... }
